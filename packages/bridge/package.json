{
  "name": "@webmcp-anything/bridge",
  "version": "0.0.1",
  "description": "Bridge server connecting browser WebMCP tools to AI agents via MCP protocol",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webmcp-bridge": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts",
    "dev": "tsx src/bin.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CodePirate7/webmcp-anything",
    "directory": "packages/bridge"
  },
  "keywords": ["mcp", "webmcp", "bridge", "websocket", "ai", "agent", "tools"],
  "license": "MIT"
}
