{
  "name": "@webmcp-anything/sdk",
  "version": "0.0.1",
  "description": "Browser SDK for webmcp-anything — Bridge client + useWebMCP re-export",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "usewebmcp": "^2.2.0"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CodePirate7/webmcp-anything",
    "directory": "packages/sdk"
  },
  "keywords": ["mcp", "webmcp", "react", "hooks", "ai", "agent", "tools", "browser"],
  "license": "MIT"
}
